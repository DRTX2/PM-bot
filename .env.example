# Copy to .env and fill with real production values.
# Never commit .env. Generate secrets with: openssl rand -hex 32

# Runtime
N8N_VERSION=2.18.7
NODE_ENV=production
GENERIC_TIMEZONE=America/Guayaquil
TZ=America/Guayaquil

# Public URL / reverse proxy
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
N8N_BIND_ADDRESS=127.0.0.1
N8N_HOST_PORT=5678
N8N_SECURE_COOKIE=true
N8N_SAMESITE_COOKIE=lax

# n8n security
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=REPLACE_WITH_ADMIN_USER
N8N_BASIC_AUTH_PASSWORD=REPLACE_WITH_LONG_RANDOM_PASSWORD
N8N_ENCRYPTION_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
N8N_RUNNERS_MODE=internal
N8N_METRICS=true
QUEUE_HEALTH_CHECK_ACTIVE=true
N8N_TEMPLATES_ENABLED=false
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_WORKFLOWS_IMPORT_DIR=./bot
N8N_WORKFLOWS_CONTAINER_DIR=/workflows/import
N8N_WORKFLOW_GROUPING_MODE=prefix

# Execution retention
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000

# PostgreSQL
POSTGRES_USER=agente
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_PASSWORD
POSTGRES_DB=proyecto_db
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
N8N_DB_SCHEMA=n8n
N8N_DB_POOL_SIZE=5

# Redis is internal-only in docker-compose.yml.

# Trello
TRELLO_API_KEY=REPLACE_WITH_TRELLO_API_KEY
TRELLO_TOKEN=REPLACE_WITH_TRELLO_TOKEN
TRELLO_BOARD_ID=REPLACE_WITH_TRELLO_BOARD_ID

# GitHub
GITHUB_TOKEN=REPLACE_WITH_LEAST_PRIVILEGE_GITHUB_TOKEN
GITHUB_TOKEN_BACKEND=REPLACE_WITH_BACKEND_TOKEN_OR_SAME
GITHUB_TOKEN_FRONTEND=REPLACE_WITH_FRONTEND_TOKEN_OR_SAME
GITHUB_OWNER=REPLACE_WITH_OWNER
GITHUB_OWNER_BACKEND=REPLACE_WITH_BACKEND_OWNER
GITHUB_OWNER_FRONTEND=REPLACE_WITH_FRONTEND_OWNER
GITHUB_REPO_BACKEND=REPLACE_WITH_BACKEND_REPO
GITHUB_REPO_FRONTEND=REPLACE_WITH_FRONTEND_REPO

# AI
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# Discord
DISCORD_WEBHOOK_URL=REPLACE_WITH_DISCORD_WEBHOOK_URL
DISCORD_WEBHOOK_URL_CHAT=REPLACE_WITH_OPTIONAL_CHAT_WEBHOOK_URL
DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_BOT_TOKEN
DISCORD_CLIENT_ID=REPLACE_WITH_DISCORD_CLIENT_ID
DISCORD_GUILD_ID=REPLACE_WITH_DISCORD_GUILD_ID
DISCORD_CHANNEL_PM=
DISCORD_CHANNEL_TAREAS=1507165378004910210
DISCORD_CHANNEL_BLOQUEOS=1507165415598456902
DISCORD_CHANNEL_REPORTES=1507165450189144124
DISCORD_CHANNEL_REUNIONES=1507165478026608801
DISCORD_CHANNEL_ENTREGABLES=1507165504031428628
DISCORD_CHANNEL_RIESGOS=1507165527850750042
DISCORD_CHANNEL_AVANCES=1507165994395631827
DISCORD_CHANNEL_BOT_LOG=1507166014767501322
DISCORD_CHANNEL_ADMIN=1507166039967006760

# PM Bot
PM_STORAGE_TYPE=postgres
PM_APPROVAL_SECRET=REPLACE_WITH_LONG_RANDOM_APPROVAL_SECRET
N8N_PM_WEBHOOK=http://localhost:5678/webhook/pm-discord-entrada
PM_FAST_PATH_ENABLED=true
PM_FAST_TIMEOUT_MS=10000
PM_CHANNEL_IDS=1507165378004910210,1507165415598456902,1507165450189144124,1507165478026608801,1507165504031428628,1507165527850750042,1507165994395631827,1507166014767501322,1507166039967006760
BOT_BRIDGE_BIND_ADDRESS=127.0.0.1
BOT_BRIDGE_PORT=3000
REDIS_URL=redis://redis:6379/0
PM_GOOGLE_SHEET_ID=
PM_NOTION_DATABASE_TASKS=
PM_NOTION_DATABASE_RISKS=
PM_NOTION_DATABASE_DECISIONS=
PM_TIMEZONE=America/Guayaquil
N8N_ENV=production
LOG_LEVEL=info

# SMTP
SMTP_HOST=REPLACE_WITH_SMTP_HOST
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM_NAME=PetSafe PM AI
SMTP_FROM_EMAIL=pm-ai@example.com

# Gotenberg
# Dentro de Docker, n8n debe usar el nombre del servicio y el puerto interno.
# Si llamas desde el host, usa http://127.0.0.1:3001
GOTENBERG_URL=http://gotenberg:3000
GOTENBERG_BIND_ADDRESS=127.0.0.1
GOTENBERG_PORT=3001
