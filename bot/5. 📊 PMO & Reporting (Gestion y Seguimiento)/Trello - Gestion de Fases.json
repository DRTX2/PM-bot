    {
      "parameters": {
        "promptType": "define",
        "text": "={{ 'Eres un asistente experto en gestión de proyectos de software. Se te proporciona el contenido de un documento técnico adjunto a una tarjeta de Trello.\\n\\nDocumento: ' + $json.filename + '\\nTamaño: ' + Math.round(($json.file_size_bytes || 0) / 1024) + ' KB\\nURL: ' + $json.url + '\\n\\nAnaliza el documento y proporciona:\\n1. Resumen ejecutivo (máx 3 oraciones)\\n2. Módulos o componentes principales cubiertos\\n3. Estado o avance implícito del trabajo\\n4. Riesgos o puntos de atención detectados\\n\\nSé conciso. Máximo 400 palabras.' }}"
