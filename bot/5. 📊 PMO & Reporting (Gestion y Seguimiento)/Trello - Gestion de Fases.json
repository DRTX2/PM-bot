    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT p.list_id, p.name, p.position, p.start_date, p.end_date, p.status, p.responsible, COALESCE(card_counts.total, 0) as total_cards, COALESCE(card_counts.done, 0) as done_cards FROM project_phases p LEFT JOIN (SELECT lista_nombre, COUNT(*) as total, SUM(CASE WHEN completada THEN 1 ELSE 0 END) as done FROM estado_tareas GROUP BY lista_nombre) card_counts ON p.name = card_counts.lista_nombre ORDER BY p.position ASC;",
        "options": {}
      },
      "id": "976869fa-df91-4267-b145-dc1c2ff19db6",
      "name": "PG List Phases",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        3344,
        112
      ],
      "credentials": {
        "postgres": {
          "id": "upx1y0H6Nw7XOqLJ",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const phases = $input.all().map(item => item.json);\nif (phases.length === 0) {\n  return [{ json: { content: '📋 No hay fases registradas. Usa `/fase sync` para sincronizar desde Trello.' } }];\n}\n\nconst statusEmoji = { active: '🔵', completed: '✅', on_hold: '⏸️' };\nconst lines = ['📋 **Fases del Proyecto PetSafe**', ''];\n\nphases.forEach((p, i) => {\n  const pct = p.total_cards > 0 ? Math.round((p.done_cards / p.total_cards) * 100) : 0;\n  const bar = '█'.repeat(Math.floor(pct / 10)) + '░'.repeat(10 - Math.floor(pct / 10));\n  const emoji = statusEmoji[p.status] || '⚪';\n  lines.push(`${emoji} **${i + 1}. ${p.name}**`);\n  if (p.start_date && p.end_date) lines.push(`   📅 ${p.start_date} → ${p.end_date}`);\n  if (p.responsible) lines.push(`   👤 ${p.responsible}`);\n  lines.push(`   ${bar} ${pct}% (${p.done_cards}/${p.total_cards} tarjetas)`);\n  lines.push(`   ID: \\`${p.list_id}\\``);\n  lines.push('');\n});\n\nreturn [{ json: { content: lines.join('\\n').slice(0, 2000) } }];"
      },
