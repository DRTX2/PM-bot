        4624,
        688
      ]
    },
    {
      "parameters": {
        "jsCode": "const action = $('Parse Phase Command').item.json.action;\nconst phase = $json;\nlet content = '';\n\nif (action === 'add') {\n  content = `✅ **Fase creada:** \\`${phase.name}\\`\\n📅 ${phase.start_date} → ${phase.end_date}\\nID: \\`${phase.list_id}\\`\\n\\n💡 Tip: Usa \\`/fase sync\\` para vincularla con Trello si ya existe la lista.`;\n} else if (action === 'edit') {\n  content = `✏️ **Fase actualizada:** \\`${phase.name}\\`\\nID: \\`${phase.list_id}\\``;\n} else if (action === 'delete') {\n  content = `🗑️ **Fase archivada:** \\`${phase.name}\\`\\n*Las tarjetas existentes no fueron afectadas.*`;\n} else if (action === 'sync') {\n  content = `🔄 **Sincronización completada.** Las fases (listas) de Trello y Tareas fueron importadas a la BD.`;\n} else {\n  content = $json.content || $json.message || 'Acción desconocida.';\n}\nreturn [{ json: { content } }];"
      },
