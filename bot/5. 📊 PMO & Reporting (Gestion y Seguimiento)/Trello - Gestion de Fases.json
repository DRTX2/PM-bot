    {
      "parameters": {
        "jsCode": "const ctx = $('Parse Phase Command').item.json;\nconst updates = ctx.updates || {};\nconst setClauses = [];\nconst params = [ctx.list_id];\nlet idx = 2;\nif (updates.nombre) { setClauses.push(`name = $${idx++}`); params.push(updates.nombre); }\nif (updates.fin) { setClauses.push(`end_date = $${idx++}`); params.push(updates.fin); }\nif (updates.inicio) { setClauses.push(`start_date = $${idx++}`); params.push(updates.inicio); }\nif (updates.responsable) { setClauses.push(`responsible = $${idx++}`); params.push(updates.responsable); }\nif (updates.estado) { setClauses.push(`status = $${idx++}`); params.push(updates.estado); }\n\nif (setClauses.length === 0) {\n  return [{ json: { skip: true, content: '⚠️ No se especificaron campos a actualizar.' } }];\n}\n\nreturn [{\n  json: {\n    query: `UPDATE project_phases SET ${setClauses.join(', ')}, updated_at = NOW() WHERE list_id = $1 RETURNING name, list_id;`,\n    params: JSON.stringify(params),\n    list_id: ctx.list_id\n  }\n}];"
      },
