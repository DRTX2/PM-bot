    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO project_phases (list_id, name, position) VALUES ($1, $2, $3) ON CONFLICT (list_id) DO UPDATE SET name = EXCLUDED.name, position = EXCLUDED.position, updated_at = NOW();",
