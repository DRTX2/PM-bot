      "parameters": {
        "jsCode": "const attachment = $('Fetch Card Attachments').first()?.json || {};\nconst summary = $json.text || attachment.summary_extracted || 'Sin resumen disponible';\nconst kb = Math.round((attachment.file_size_bytes || 0) / 1024);\nconst content = `📎 **${attachment.filename}** (${kb} KB)\\n\\n${summary}\\n\\n*Resumen generado por IA — extrae sólo metadatos y contexto*`;\nreturn [{ json: { content: content.slice(0, 2000) } }];"
      },
      "id": "fbb00d6c-7671-4790-8b0e-4e3f4b57a215",
      "name": "Format PDF Response",
      "type": "n8n-nodes-base.code",
