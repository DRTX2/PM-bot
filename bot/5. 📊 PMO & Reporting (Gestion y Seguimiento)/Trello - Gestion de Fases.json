    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO project_phases (list_id, name, start_date, end_date, position) VALUES (gen_random_uuid()::text, $1, $2, $3, (SELECT COALESCE(MAX(position),0)+1 FROM project_phases)) RETURNING list_id, name, start_date, end_date;",
        "options": {
          "queryReplacement": "={{ [$('Parse Phase Command').item.json.name, $('Parse Phase Command').item.json.start_date, $('Parse Phase Command').item.json.end_date] }}"
        }
      },
