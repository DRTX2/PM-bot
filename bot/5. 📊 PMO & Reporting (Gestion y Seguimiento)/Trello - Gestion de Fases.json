      "parameters": {
        "jsCode": "const lists = $input.all().map(item => item.json).filter(l => !l.closed);\nconst upserts = lists.map((l, idx) => [\n  l.id, l.name, idx + 1\n]);\nreturn upserts.map((row, idx) => ({ json: { list_id: row[0], name: row[1], position: row[2] } }));"
