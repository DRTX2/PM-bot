        "jsCode": "const d = $json;\nreturn [{\n  json: {\n    correlation_id: d.correlation_id,\n    agent_role: 'PM Orchestrator',\n    decision_type: 'routing',\n    input_summary: `Event: ${d.event_type} from ${d.source}`,\n    context_used: { event_details: d.payload },\n    evidence: {},\n    decision: { routed_to: d.assigned_agent, priority: d.priority },\n    recommendation: d.reasoning,\n    confidence: 0.95,\n    risk_level: d.priority,\n    requires_human_approval: d.requires_human_approval\n  }\n}];"
      },
