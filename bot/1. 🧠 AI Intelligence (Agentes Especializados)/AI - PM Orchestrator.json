    {
      "parameters": {
        "jsCode": "// Preserve both the routing decision AND the original context for sub-agents\nconst parsed = $json;\nconst ctx = $('Prepare Context').item.json;\n\nconst validAgents = ['CodeReviewScout', 'RiskAnalyst', 'ContextGuardian', 'ReleaseGuard', 'None'];\nlet normalizedAgent = String(parsed.assigned_agent || 'None').trim();\nconst releaseHints = [ctx.event_type, ctx.payload, ctx.source].filter(Boolean).join(' ').toLowerCase();\nif (/github_pr_merged|release|deploy|deployment|main|master|qa|produccion|producción/.test(releaseHints)) {\n  normalizedAgent = 'ReleaseGuard';\n}\n\nreturn [{\n  json: {\n    ...ctx,\n    assigned_agent: validAgents.includes(normalizedAgent) ? normalizedAgent : 'None',\n    reasoning: parsed.reasoning || '',\n    priority: parsed.priority || 'low',\n    requires_human_approval: Boolean(parsed.requires_human_approval)\n  }\n}];"
      },
