    {
      "parameters": {
        "jsCode": "const ctx = $json;\nconst source = String(ctx.source || '').toLowerCase();\nconst type = String(ctx.event_type || '').toLowerCase();\nconst payloadText = String(ctx.payload || '').toLowerCase();\nconst blob = [source, type, payloadText].join(' ');\nconst emptyPayload = !ctx.payload || ctx.payload === '{}' || ctx.payload === 'null';\n\nlet assigned_agent = 'None';\nlet reasoning = 'Evento informativo sin accion PM.';\nlet priority = 'low';\nlet requires_human_approval = false;\n\nif ((!source || source === 'unknown') && (!type || type === 'unknown') && emptyPayload) {\n  assigned_agent = 'None'; reasoning = 'Evento sin fuente, tipo ni payload util.';\n} else if (/finops|presupuesto|budget|burn.rate|costo|gasto|earned.value|cpi|eac/.test(blob)) {\n  assigned_agent = 'FinOps'; reasoning = 'Solicitud financiera o de presupuesto.'; priority = 'medium';\n} else if (/capacidad|capacity|forecast|pto|vacacion|ausencia|proyeccion|what.if|escenario/.test(blob)) {\n  assigned_agent = 'CapacityForecaster'; reasoning = 'Solicitud de capacidad, PTOs o proyeccion.'; priority = 'medium';\n} else if (/onboarding|nuevo.miembro|new.member|guild_member_add|bienvenida|welcome/.test(blob)) {\n  assigned_agent = 'TeamOnboarding'; reasoning = 'Nuevo integrante detectado.'; priority = 'medium';\n} else if (/calidad|quality|qa|bug.report|deuda.tecnica|tech.debt|reopen|cobertura|coverage/.test(blob)) {\n  assigned_agent = 'QualityLead'; reasoning = 'Solicitud de revision de calidad o deuda tecnica.'; priority = 'medium';\n} else if (/retro|retrospectiva|sprint_end|postmortem|post.mortem|mejora|agile_coach/.test(blob)) {\n  assigned_agent = 'AgileCoach'; reasoning = 'Evento de ceremonia agil o post-mortem.'; priority = /postmortem|ci_fail|critical/.test(blob) ? 'high' : 'medium'; requires_human_approval = /postmortem/.test(blob);\n} else if (/stakeholder|sponsor|reporte.ejecutivo|executive|negocio|business/.test(blob)) {\n  assigned_agent = 'StakeholderLiaison'; reasoning = 'Reporte para stakeholders o negocio.'; priority = 'medium';\n} else if (/github_pr_merged|release|deploy|deployment|production|produccion|ci_failed|pipeline|build/.test(blob)) {\n  assigned_agent = 'ReleaseGuard'; reasoning = 'Evento de release, deploy o CI.'; priority = /failed|error|critical|prod/.test(blob) ? 'high' : 'medium';\n} else if (/github|pull_request|pr|commit|branch|code|bug|fix|feat|merge/.test(blob)) {\n  assigned_agent = 'CodeReviewScout'; reasoning = 'Evento tecnico de GitHub.'; priority = /hotfix|bug|failed|critical/.test(blob) ? 'high' : 'medium';\n} else if (/risk|riesgo|bloqueo|blocked|deadline|overdue|vencid|workload|carga/.test(blob)) {\n  assigned_agent = 'RiskAnalyst'; reasoning = 'Evento con señales de riesgo o carga.'; priority = /critical|alto|high|bloqueo|overdue/.test(blob) ? 'high' : 'medium';\n} else if (/trello|card|pdf|document|requisito|arquitectura|decision|alcance/.test(blob)) {\n  assigned_agent = 'ContextGuardian'; reasoning = 'Evento de tablero o contexto.'; priority = /cliente|entrega|aprobacion/.test(blob) ? 'medium' : 'low';\n} else {\n  assigned_agent = 'RiskAnalyst'; reasoning = 'Evento ambiguo, triage PM.';\n}\n\nreturn [{ json: { assigned_agent, reasoning, priority, requires_human_approval } }];"
      },
