    {
      "parameters": {
        "jsCode": "const ctx = $('Verify Merged & Extract Context').item.json;\nconst content = [\n  `🔀 **PR Mergeado** en \\`${ctx.repo}\\``,\n  `📌 **PR #${ctx.pr_number}:** ${ctx.pr_title}`,\n  `🌿 Branch: \\`${ctx.branch}\\``,\n  `👤 Autor: **${ctx.actor}**`,\n  `🔗 Commit: \\`${ctx.sha}\\``,\n  ctx.trello_card_id ? `✅ Tarjeta Trello \\`${ctx.trello_card_id}\\` archivada y comentada.` : `⚠️ No se encontró referencia a Trello en el branch/título.`,\n  ``,\n  `🧑‍💻 **Testers:** Por favor verifiquen la build correspondiente.`\n].join('\\n');\n\nreturn [{ json: { content } }];"
      },
