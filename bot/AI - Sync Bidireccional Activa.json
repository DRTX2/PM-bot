{
  "name": "AI - Sync Bidireccional Activa",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const payload = $json;\nconst action = payload.action;\nconst pr = payload.pull_request || {};\nconst merged = pr.merged === true;\nconst branch = (pr.head || {}).ref || '';\nconst actor = (pr.merged_by || pr.user || {}).login || 'unknown';\n\n// Extraer card ID de Trello desde el nombre del branch o título del PR\n// Convencion: branch name o titulo contiene 'trello-CARDID'\nconst cardMatch = (branch + ' ' + (pr.title || '')).match(/trello-([a-zA-Z0-9]+)/);\nconst trelloCardId = cardMatch ? cardMatch[1] : null;\n\nif (action !== 'closed' || !merged) {\n  return [{ json: { skip: true, reason: `PR action=${action}, merged=${merged}` } }];\n}\n\nreturn [{\n  json: {\n    skip: false,\n    action,\n    merged,\n    pr_number: pr.number,\n    pr_title: pr.title || '',\n    branch,\n    actor,\n    trello_card_id: trelloCardId,\n    repo: (payload.repository || {}).name || '',\n    sha: (pr.merge_commit_sha || '').slice(0, 7),\n    correlation_id: `sync-pr-${pr.number}-${Date.now()}`\n  }\n}];"
      },
      "id": "821ce096-59e9-4937-8542-ee525f06d64d",
      "name": "Verify Merged & Extract Context",
