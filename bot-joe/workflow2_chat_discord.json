      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        400
      ],
      "parameters": {
        "jsCode": "const pregunta = ($node['Config'].json.pregunta_usuario || '').trim();\nconst low = pregunta.toLowerCase();\n\nlet tipo = 'chat';\nif (low.startsWith('!reporte')) tipo = 'reporte';\nelse if (low.startsWith('!kpis')) tipo = 'kpis';\n\nconst necesita_diff = /(codig|commit|diff|revisa|calidad|pull request|\\bpr\\b|merge)/.test(low);\n\nreturn [{ json: { pregunta, tipo, necesita_diff, usuario: $node['Config'].json.usuario_discord } }];"
      }
