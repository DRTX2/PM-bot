      "position": [
        1120,
        320
      ],
      "parameters": {
        "jsCode": "const row = $json;\nconst k = row.kpis_json || {};\nconst lines = [\n  'KPIs PetSafe (' + new Date(row.fecha_ejecucion).toLocaleString('es-EC') + ')',\n  '',\n  'Progreso sprint: ' + row.progreso_pct + '%',\n  'Tareas vencidas: ' + row.tareas_vencidas,\n  'Velocidad: ' + k.velocidad_tareas_por_dia + ' tareas/dÃƒÆ’Ã‚Â­a (completadas 7d: ' + k.completadas_7d + ')',\n  '% a tiempo: ' + k.pct_a_tiempo + '%',\n  'Commits 14d: ' + k.commits_14d + ' (' + k.commits_por_dia + '/dÃƒÆ’Ã‚Â­a)',\n  'PR avg open: ' + k.pr_open_time_dias + ' dÃƒÆ’Ã‚Â­as',\n  'PR merge ratio 30d: ' + k.pr_merge_ratio_30d + '%',\n  'DÃƒÆ’Ã‚Â­as hasta fin: ' + k.dias_hasta_fin,\n  'ProyecciÃƒÆ’Ã‚Â³n: ' + k.proyeccion\n];\nreturn [{ json: { text: lines.join('\\n') } }];"
      }
