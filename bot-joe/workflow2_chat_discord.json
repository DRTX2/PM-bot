                "conditions": [
                  {
                    "leftValue": "={{ $json.tipo }}",
                    "rightValue": "reporte",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "outputKey": "reporte"
            },
            {
