    {
      "id": "contexto",
      "name": "Construir Contexto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1900,
        800
      ],
      "parameters": {
        "jsCode": "const now = new Date();\nconst pregunta = $('Router Comandos').first().json.pregunta;\nconst usuario = $('Router Comandos').first().json.usuario;\nconst needDiff = $('Router Comandos').first().json.necesita_diff;\n\nconst cards = $('Trello Cards').all().map(i => i.json);\nconst lists = $('Trello Lists').all().map(i => i.json);\nconst members = $('Trello Members').all().map(i => i.json);\nconst bCommits = $('GH Back Commits').all().map(i => i.json);\nconst fCommits = $('GH Front Commits').all().map(i => i.json);\nconst bPRs = $('GH Back PRs').all().map(i => i.json);\nconst fPRs = $('GH Front PRs').all().map(i => i.json);\nconst historial = $('PG Historial').all().map(i => i.json);\nconst recos = $('PG Recomendaciones').all().map(i => i.json);\nconst hitos = $('PG Hitos').all().map(i => i.json);\n\nlet diffBack = null, diffFront = null;\nif (needDiff) {\n  try { diffBack = $('Diff Backend').first().json; } catch (e) {}\n  try { diffFront = $('Diff Frontend').first().json; } catch (e) {}\n}\n\nconst listaById = {};\nlists.forEach(l => { if (l?.id) listaById[l.id] = l.name; });\nconst memberById = {};\nmembers.forEach(m => { if (m?.id) memberById[m.id] = m.fullName || m.username; });\n\nconst tareas = cards.map(c => {\n  const due = c.due ? new Date(c.due) : null;\n  const vencida = due && !c.dueComplete && due < now;\n  const diasRest = due ? Math.floor((due - now) / 86400000) : null;\n  return {\n    nombre: c.name,\n    lista: listaById[c.idList] || 'desconocida',\n    completada: !!c.dueComplete,\n    fecha_limite: c.due,\n    dias_restantes: diasRest,\n    vencida: !!vencida,\n    responsables: (c.idMembers || []).map(id => memberById[id] || id),\n  };\n});\n\nconst vencidas = tareas.filter(t => t.vencida);\nconst porVencer = tareas.filter(t => !t.completada && !t.vencida && t.dias_restantes !== null && t.dias_restantes <= 3);\n\nconst ultimoAnalisis = historial[0] || null;\nconst kpis = ultimoAnalisis?.kpis_json || null;\n\nconst simplifyPR = p => ({ numero: p.number, titulo: p.title, estado: p.state, autor: p.user?.login, creado: p.created_at, dias_abierto: Math.floor((now - new Date(p.created_at)) / 86400000) });\nconst prsAbiertos = [...bPRs.map(simplifyPR), ...fPRs.map(simplifyPR)].filter(p => p.estado === 'open');\nconst prsStale = prsAbiertos.filter(p => p.dias_abierto > 7);\n\nconst simplifyCommit = c => ({ sha: (c.sha || '').slice(0, 7), mensaje: (c.commit?.message || '').split('\\n')[0], autor: c.commit?.author?.name, fecha: c.commit?.author?.date });\n\nlet diffInfo = null;\nif (diffBack || diffFront) {\n  const shapeDiff = d => d ? {\n    sha: d.sha?.slice(0, 7), mensaje: d.commit?.message, autor: d.commit?.author?.name,\n    archivos: (d.files || []).map(f => ({ archivo: f.filename, cambios: f.changes, patch: (f.patch || '').slice(0, 1200) }))\n  } : null;\n  diffInfo = { backend: shapeDiff(diffBack), frontend: shapeDiff(diffFront) };\n}\n\nconst hoy = now.toISOString().slice(0, 10);\nconst hitosActivos = hitos.filter(h => h.fecha_fin >= hoy).map(h => ({\n  nombre: h.nombre, tipo: h.tipo, fecha_fin: h.fecha_fin,\n  dias_faltan: Math.floor((new Date(h.fecha_fin) - now) / 86400000),\n  responsable: h.responsable\n}));\n\nconst ctx = {\n  fecha_actual: now.toISOString(), usuario,\n  tareas: {\n    total: tareas.length, vencidas, por_vencer_3dias: porVencer,\n    completadas_count: tareas.filter(t => t.completada).length,\n    distribucion: tareas.reduce((a, t) => { a[t.lista] = (a[t.lista] || 0) + 1; return a; }, {})\n  },\n  github: {\n    commits_back_recientes: bCommits.slice(0, 8).map(simplifyCommit),\n    commits_front_recientes: fCommits.slice(0, 8).map(simplifyCommit),\n    prs_abiertos: prsAbiertos, prs_stale_mas_7d: prsStale\n  },\n  kpis_ultimo_analisis: kpis,\n  hitos_proximos: hitosActivos.slice(0, 5),\n  historial_resumen: historial.map(h => ({ fecha: h.fecha_ejecucion, problemas: h.hay_problemas, vencidas: h.tareas_vencidas, progreso: h.progreso_pct })),\n  recomendaciones_previas: recos.map(r => ({ pregunta: (r.pregunta || '').slice(0, 120), respuesta: (r.respuesta || '').slice(0, 250), aplicada: r.aplicada, fecha: r.fecha })),\n  diff_commits: diffInfo\n};\n\nconst prompt = `Eres asistente experto de gestion del proyecto PetSafe. Copiloto del gestor para decisiones.\n\nREGLAS:\n1. SOLO respondes sobre el proyecto (Trello, GitHub, tareas, commits, PRs, equipo, riesgos, hitos, KPIs). Si no: responde EXACTAMENTE \"No es una pregunta relacionada con el proyecto.\"\n2. Espanol, texto plano, sin markdown, sin asteriscos, sin emojis, maximo 1800 caracteres.\n3. Siempre basado en datos reales del contexto. Si falta dato, dilo.\n4. Si preguntan que hacer, riesgos, decisiones: usa DIAGNOSTICO / RIESGOS / ACCIONES RECOMENDADAS.\n5. Si piden review de codigo y hay diff_commits, analiza calidad, bugs potenciales, buenas practicas.\n6. Si la pregunta es simple (ej \"hay vencidas?\"), responde directo.\n7. Considera hitos proximos y dias hasta fin para contextualizar urgencia.\n8. Menciona recomendaciones previas no aplicadas si son relevantes.\n\nCONTEXTO (fecha ${now.toISOString()}):\n${JSON.stringify(ctx, null, 2)}\n\nPREGUNTA DE ${usuario}:\n${pregunta}`;\n\nreturn [{ json: { prompt, gemini_key: $('Config').first().json.GEMINI_API_KEY, pregunta, usuario } }];"
      }
    },
    {
      "id": "gemini",
      "name": "Gemini Chat",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2140,
